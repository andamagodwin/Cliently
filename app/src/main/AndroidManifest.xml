<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Cliently">

        <!-- LAUNCHER: Login screen -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".CustomerListActivity"
            android:exported="false"/>

        <activity
            android:name=".CustomerDetailActivity"
            android:exported="false"
            android:parentActivityName=".CustomerListActivity"/>

        <activity
            android:name=".AddOrderActivity"
            android:exported="false"
            android:parentActivityName=".CustomerDetailActivity"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".ProductListActivity"
            android:exported="false"
            android:parentActivityName=".CustomerListActivity"/>

        <activity
            android:name=".AddProductActivity"
            android:exported="false"
            android:parentActivityName=".ProductListActivity"
            android:windowSoftInputMode="adjustResize"/>

    </application>

</manifest>